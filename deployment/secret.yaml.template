apiVersion: v1
kind: Secret
metadata:
  name: kubernetes-agent
type: Opaque
stringData:

  # SAP AI Core Configuration (required when using aicore profile)
  sap_aicore_client_id: "<your-client-id>"
  sap_aicore_client_secret: "<your-client-secret>"
  sap_aicore_auth_url: "<your-auth-url>"
  sap_aicore_api_url: "<your-api-url>"
  sap_aicore_deployment_id: "<your-deployment-id>"
  sap_aicore_resource_group: "default"
  sap_aicore_model_name: "gpt-5"
  sap_aicore_model_version: "latest"
  aicore_service_key: '{"clientid":"<your-client-id>","clientsecret":"<your-client-secret>","url":"<your-auth-url>","identityzone":"<identity-zone>","identityzoneid":"<identity-zone-id>","appname":"<app-name>","credential-type":"binding-secret","serviceurls":{"AI_API_URL":"<AI-API-URL>"}}'

  
  # GitHub Configuration (required for PR creation)
  github_token: "<your-github-token>"
